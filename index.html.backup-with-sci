<strong>給您 frame：</strong>APS 是您 medical reality 的 part — 不是您 whole identity。Same way someone has type 1 diabetes lifelong — manageable、not life-defining。Stroke recovery + APS management 是 marathon not sprint。我們 team 陪您 long-term。</p>

<p style="background:var(--bg);padding:14px;border-left:2px solid var(--accent);margin:8px 0;">
<strong>家屬：</strong>姊姊 28 歲 — aPL screening 即可（asymptomatic 但 family screening recommended）。父母年紀大、no aPL screening typically needed unless symptomatic。未來 children — 童年 no routine screening；teen / young adult any thrombosis or pregnancy event → 當下 workup。</p>

<p style="background:var(--bg);padding:14px;border-left:2px solid var(--accent);margin:8px 0;">
<strong>最後：</strong>您 walked into 我 office 兩個月前 facing 「為什麼是我」 — 我希望 today 您 walk out 可能 not with answer，but with framework + plan + team。Long road、but you're not alone。」</p>

<h4>口試重點</h4>

<ul>
<li>APS 多 organ thrombosis potential（不只 stroke）</li>
<li>Triple positive 高 recurrence risk</li>
<li>CAPS 概念 + recognition + treatment</li>
<li>SLE development 10-30% 風險</li>
<li>Annual surveillance comprehensive checklist</li>
<li>Warfarin long-term considerations（bone、bleeding、interactions）</li>
<li>HCQ retinal monitoring</li>
<li>Lifestyle integration（travel、surgery、exercise、diet）</li>
<li>Future emerging therapies awareness</li>
<li>Multidisciplinary team coordination</li>
<li>Patient empowerment（INR self-monitoring、advocacy）</li>
<li>家屬 screening 個別化建議</li>
<li>Long-term hope + realistic framework</li>
</ul>`,
      },
    ],
  },
];

const SECONDS_PER_CASE = 540;

const fmtTime = (s) => {
  const m = Math.floor(s / 60);
  const sec = s % 60;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
};

const shuffle = (arr) => {
  const copy = [...arr];
  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }
  return copy;
};

const casesByDomain = (id) => CASES.filter(c => c.domain === id);

function Landing({ onStart }) {
  const [selectedDomain, setSelectedDomain] = useState(null);
  const availableCases = selectedDomain ? casesByDomain(selectedDomain) : [];

  return (
    <div className="container">
      <div className="landing-header">
        <div className="eyebrow">Physical Medicine & Rehabilitation</div>
        <h1 className="landing-title">
          Oral Examination<br/>
          <span className="tc">復健科專科口試模擬</span>
        </h1>
        <p className="landing-sub">
          每大題九分鐘，模擬真實口試節奏。倒數結束自動結束本題。
          作答以口述為主，作答完畢後顯示完整詳解。
        </p>
      </div>

      <div className="config-group">
        <div className="section-label">DOMAIN — 選擇領域</div>
        <div className="domain-grid">
          {DOMAINS.map((d, i) => {
            const n = casesByDomain(d.id).length;
            const disabled = n === 0;
            return (
              <button
                key={d.id}
                className={`domain-cell ${selectedDomain === d.id ? 'active' : ''}`}
                onClick={() => !disabled && setSelectedDomain(d.id)}
                disabled={disabled}
              >
                <div className="domain-num">{String(i+1).padStart(2,'0')}</div>
                <div className="domain-name-en">{d.en}</div>
                <div className="domain-name-tc">{d.tc}</div>
                <div className="domain-count">{n} CASE{n !== 1 ? 'S' : ''}</div>
              </button>
            );
          })}
        </div>
      </div>

      {selectedDomain && availableCases.length > 0 && (
        <>
          <div className="config-group">
            <div className="section-label">CASE — 選擇題目</div>
            <div className="config-label">每場考試為 1 大題（與實際國考相同）</div>
            <div className="case-pick-list">
              {availableCases.map((c, i) => (
                <button
                  key={c.id}
                  className="case-pick-btn"
                  onClick={() => onStart(c)}
                >
                  <div className="case-pick-num">CASE {String(i+1).padStart(2,'0')}</div>
                  <div className="case-pick-title">模擬題 {i+1}</div>
                  <div className="case-pick-meta">{c.questions.length} 小題 · 9 分鐘</div>
                  <div className="case-pick-arrow">→</div>
                </button>
              ))}
            </div>
          </div>
        </>
      )}

      {selectedDomain && availableCases.length === 0 && (
        <div style={{textAlign:'center', padding:'48px 0', color:'var(--text-faint)', fontFamily:'var(--mono)', fontSize:12, letterSpacing:'0.2em'}}>
          此領域題庫尚未建置
        </div>
      )}

      {!selectedDomain && (
        <div style={{textAlign:'center', padding:'48px 0', color:'var(--text-faint)', fontFamily:'var(--mono)', fontSize:12, letterSpacing:'0.2em'}}>
          請先選擇領域
        </div>
      )}
    </div>
  );
}

function CaseIntro({ caseData, onReady, onHome }) {
  const domain = DOMAINS.find(d => d.id === caseData.domain);
  const domainCases = casesByDomain(caseData.domain);
  const caseNum = domainCases.findIndex(c => c.id === caseData.id) + 1;
  return (
    <div className="case-screen">
      <div className="case-header">
        <button className="home-link" onClick={onHome}>← 回首頁</button>
        <div className="case-title">臨床情境</div>
        <div className="case-progress">
          {domain && <span style={{color:'var(--accent)'}}>{domain.tc}</span>}
          {' · 模擬題 '}{caseNum}
        </div>
      </div>
      <div className="case-body">{caseData.context}</div>
      <button className="start-btn" onClick={onReady}>
        準備好了，開始作答 →
      </button>
      <div className="ready-note">
        進入後 9 分鐘倒數開始 · 自行掌控小題節奏
      </div>
    </div>
  );
}

function CaseRunner({ caseData, onCaseEnd, onHome }) {
  const [remaining, setRemaining] = useState(SECONDS_PER_CASE);
  const [qIdx, setQIdx] = useState(0);
  const [timeUp, setTimeUp] = useState(false);
  const [showEndConfirm, setShowEndConfirm] = useState(false);
  const [showContext, setShowContext] = useState(false);
  const [showHomeConfirm, setShowHomeConfirm] = useState(false);
  // qTimings[i] = { seconds: 累計秒數, timeout: bool, visited: bool }
  const [qTimings, setQTimings] = useState({});
  const totalQ = caseData.questions.length;
  const onCaseEndRef = useRef(onCaseEnd);
  onCaseEndRef.current = onCaseEnd;

  // 紀錄當前小題「這次進入」的開始時刻（以 case 開始後經過的秒數計）
  const qStartElapsedRef = useRef(0);
  // 用 ref 持有最新 qIdx 和 qTimings，避免 timer 拿到 stale closure
  const qIdxRef = useRef(qIdx);
  const qTimingsRef = useRef(qTimings);
  qIdxRef.current = qIdx;
  qTimingsRef.current = qTimings;

  useEffect(() => {
    setRemaining(SECONDS_PER_CASE);
    setQIdx(0);
    setTimeUp(false);
    setQTimings({});
    qStartElapsedRef.current = 0;
  }, [caseData.id]);

  useEffect(() => {
    if (timeUp) return;
    const timer = setInterval(() => {
      setRemaining(prev => {
        if (prev <= 1) {
          clearInterval(timer);
          // 計時器到 → 結算當前小題剩餘的這段時間，累計上去
          const elapsed = SECONDS_PER_CASE;
          const spentThisVisit = elapsed - qStartElapsedRef.current;
          const currentQ = qIdxRef.current;
          const prevTiming = qTimingsRef.current[currentQ];
          const accumulated = (prevTiming?.seconds || 0) + spentThisVisit;
          setQTimings(t => ({
            ...t,
            [currentQ]: { seconds: accumulated, timeout: true, visited: true }
          }));
          setTimeUp(true);
          return 0;
        }
        return prev - 1;
      });
    }, 1000);
    return () => clearInterval(timer);
  }, [caseData.id, timeUp]);

  // 將「這次停留在當前小題的時間」累加進去，並把 qStart 移到現在
  const accumulateCurrentQTime = () => {
    const elapsed = SECONDS_PER_CASE - remaining;
    const spentThisVisit = elapsed - qStartElapsedRef.current;
    if (spentThisVisit > 0) {
      setQTimings(t => {
        const prev = t[qIdx];
        return {
          ...t,
          [qIdx]: {
            seconds: (prev?.seconds || 0) + spentThisVisit,
            timeout: false,
            visited: true,
          }
        };
      });
    } else {
      // 即使停留 0 秒，也標記為 visited（代表使用者有經過這題）
      setQTimings(t => ({
        ...t,
        [qIdx]: { seconds: t[qIdx]?.seconds || 0, timeout: false, visited: true }
      }));
    }
    qStartElapsedRef.current = elapsed;
  };

  const handleNextQ = () => {
    if (qIdx + 1 < totalQ) {
      accumulateCurrentQTime();
      setQIdx(qIdx + 1);
    } else {
      setShowEndConfirm(true);
    }
  };

  const handlePrevQ = () => {
    if (qIdx > 0) {
      accumulateCurrentQTime();
      setQIdx(qIdx - 1);
    }
  };

  const handleConfirmEnd = () => {
    accumulateCurrentQTime();
    setShowEndConfirm(false);
    // 用 setTimeout 確保 state 更新後再傳出去
    setTimeout(() => {
      onCaseEndRef.current(qTimingsRef.current, qIdxRef.current);
    }, 0);
  };

  const handleTimeUpEnd = () => {
    onCaseEndRef.current(qTimingsRef.current, qIdxRef.current);
  };

  // 鍵盤快捷鍵
  useEffect(() => {
    const onKey = (e) => {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      if (e.code === 'KeyH' || (e.code === 'Space' && !showEndConfirm && !timeUp)) {
        e.preventDefault();
        setShowContext(prev => !prev);
      } else if (e.code === 'Escape') {
        setShowContext(false);
      }
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [showEndConfirm, timeUp]);

  const pct = (remaining / SECONDS_PER_CASE) * 100;
  const cls = remaining <= 60 ? 'danger' : '';
  const domain = DOMAINS.find(d => d.id === caseData.domain);

  return (
    <div className="question-screen">
      <div className="q-top">
        <button className="home-link" onClick={() => setShowHomeConfirm(true)}>
          ← 回首頁
        </button>
        <div className="q-marker">
          {domain && <span className="accent">{domain.tc}</span>}
          {' · QUESTION '}{qIdx + 1}/{totalQ}
        </div>
        <div className={`timer ${cls}`}>{fmtTime(remaining)}</div>
      </div>

      <div className="progress-bar">
        <div className={`progress-fill ${cls}`} style={{width: `${pct}%`}}></div>
      </div>

      <div className="subq-dots">
        {Array.from({length: totalQ}).map((_, i) => (
          <div key={i} className={`subq-dot ${i < qIdx ? 'done' : i === qIdx ? 'current' : ''}`}></div>
        ))}
      </div>

      <div className="q-body">
        <div className="q-text">{caseData.questions[qIdx].q}</div>
      </div>

      <div className="q-controls">
        <button className="ctrl-btn" onClick={() => setShowContext(true)}>
          📋 查看題幹
        </button>
        <div className="q-btns">
          {qIdx > 0 && (
            <button className="ctrl-btn" onClick={handlePrevQ}>← 上一題</button>
          )}
          <button className="ctrl-btn primary" onClick={handleNextQ}>
            {qIdx + 1 < totalQ ? '下一題 →' : '完成此大題 ✓'}
          </button>
        </div>
      </div>

      {showContext && (
        <div className="ctx-modal-bg" onClick={() => setShowContext(false)}>
          <div className="ctx-modal" onClick={(e) => e.stopPropagation()}>
            <div className="ctx-modal-header">
              <div className="ctx-modal-title">CASE CONTEXT — 題幹</div>
              <button className="ctx-modal-close" onClick={() => setShowContext(false)}>
                關閉 ESC
              </button>
            </div>
            <div className="ctx-modal-body">{caseData.context}</div>
            <div className="ctx-modal-footer">
              快捷鍵 <kbd>H</kbd> 或 <kbd>SPACE</kbd> 開關 · 計時器持續進行
            </div>
          </div>
        </div>
      )}

      {timeUp && (
        <div className="timeup-overlay">
          <div className="timeup-mark">TIME UP</div>
          <div className="timeup-title">時間到</div>
          <div className="timeup-sub">本大題作答時間結束</div>
          <button className="start-btn" style={{maxWidth:280}} onClick={handleTimeUpEnd}>
            查看完整詳解 →
          </button>
        </div>
      )}

      {showEndConfirm && (
        <div className="modal-bg">
          <div className="modal">
            <div className="modal-title">結束此大題？</div>
            <div className="modal-text">你已回答完所有小題。確認結束後將進入下一階段，剩餘時間將不被使用。</div>
            <div className="modal-btns">
              <button className="modal-btn" onClick={() => setShowEndConfirm(false)}>繼續使用時間</button>
              <button className="modal-btn primary" onClick={handleConfirmEnd}>
                結束本大題
              </button>
            </div>
          </div>
        </div>
      )}

      {showHomeConfirm && (
        <div className="modal-bg">
          <div className="modal">
            <div className="modal-title">回到首頁？</div>
            <div className="modal-text">目前作答進度與計時將不會保留。確認離開？</div>
            <div className="modal-btns">
              <button className="modal-btn" onClick={() => setShowHomeConfirm(false)}>繼續作答</button>
              <button className="modal-btn primary" onClick={onHome}>
                離開回首頁
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

function Results({ activeCase, caseTiming, onRestart }) {
  const [allOpen, setAllOpen] = useState(false);
  const [bulkKey, setBulkKey] = useState(0);

  const handleExpandAll = () => {
    setAllOpen(true);
    setBulkKey(k => k + 1);
  };
  const handleCollapseAll = () => {
    setAllOpen(false);
    setBulkKey(k => k + 1);
  };

  if (!activeCase) {
    return (
      <div className="results-screen">
        <button className="restart-btn" onClick={onRestart}>← 回到首頁</button>
      </div>
    );
  }

  const domain = DOMAINS.find(d => d.id === activeCase.domain);
  const timings = caseTiming || { timings: {}, lastQIdx: -1 };

  return (
    <div className="results-screen">
      <div className="results-header">
        <button className="home-link results-home" onClick={onRestart}>← 回首頁</button>
        <div className="eyebrow">Examination Complete</div>
        <h1 className="results-title">完整詳解</h1>
        <p className="results-sub">點擊任一題目可展開詳解。每題作答時間顯示於右側。</p>
      </div>

      <div className="results-controls">
        <button className="expand-btn" onClick={handleExpandAll}>全部展開</button>
        <button className="expand-btn" onClick={handleCollapseAll}>全部收起</button>
      </div>

      <div className="case-block">
        <div className="case-block-header">
          <div className="case-block-num">CASE</div>
          <div className="case-block-title">{activeCase.title}</div>
          {domain && <div className="case-domain-tag">{domain.tc}</div>}
        </div>
        <div className="case-context">{activeCase.context}</div>
        {activeCase.questions.map((qa, qi) => (
          <QABlockWrapper
            key={`${qi}-${bulkKey}`}
            qa={qa}
            qi={qi}
            timing={timings.timings[qi]}
            defaultOpen={allOpen}
          />
        ))}
      </div>

      <button className="restart-btn" onClick={onRestart}>← 回到首頁</button>
    </div>
  );
}

function QABlockWrapper({ qa, qi, timing, defaultOpen }) {
  const [open, setOpen] = useState(defaultOpen);

  let timeBadge;
  if (timing && timing.visited) {
    timeBadge = (
      <div className={`qa-time ${timing.timeout ? 'timeout' : ''}`}>
        {timing.timeout && '⏱ '}{fmtTime(timing.seconds)}{timing.timeout && ' · 時間到'}
      </div>
    );
  } else {
    timeBadge = <div className="qa-time unanswered">未作答</div>;
  }

  return (
    <div className="qa-block">
      <div className={`qa-card ${open ? 'open' : ''}`}>
        <div className="qa-summary" onClick={() => setOpen(!open)}>
          <span className="qa-chevron">▶</span>
          <span className="qa-q-num">Q{String(qi+1).padStart(2,'0')}</span>
          <span className="qa-q-summary">{qa.q}</span>
          {timeBadge}
        </div>
        {open && (
          <div className="qa-expanded">
            {(qa.keywords && qa.keywords.length > 0) && (
              <div className="det-section">
                <div className="det-section-label">關鍵字 KEYWORDS</div>
                <div className="keyword-list">
                  {qa.keywords.map((k, i) => (
                    <span key={i} className={`keyword-tag ${/^[A-Za-z0-9\s\-\/&,\.\(\)]+$/.test(k) ? 'en' : ''}`}>{k}</span>
                  ))}
                </div>
              </div>
            )}
            {(qa.points && qa.points.length > 0) && (
              <div className="det-section">
                <div className="det-section-label">應提到的要點 KEY POINTS</div>
                <ul className="points-list">
                  {qa.points.map((p, i) => (
                    <li key={i} dangerouslySetInnerHTML={{__html: p}}></li>
                  ))}
                </ul>
              </div>
            )}
            {qa.a && (
              <div className="det-section">
                <div className="det-section-label">完整詳解 DETAIL</div>
                <div className="det-content" dangerouslySetInnerHTML={{__html: qa.a}}></div>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

function App() {
  const [phase, setPhase] = useState('landing');
  const [activeCase, setActiveCase] = useState(null);
  // caseTiming = { timings: {qIdx: {seconds, timeout}}, lastQIdx }
  const [caseTiming, setCaseTiming] = useState({ timings: {}, lastQIdx: -1 });

  const handleStart = (caseObj) => {
    setActiveCase(caseObj);
    setCaseTiming({ timings: {}, lastQIdx: -1 });
    setPhase('intro');
  };

  const handleReady = () => setPhase('running');

  const handleCaseEnd = (timings, lastQIdx) => {
    setCaseTiming({ timings: timings || {}, lastQIdx: lastQIdx ?? -1 });
    setPhase('results');
  };

  const handleRestart = () => {
    setPhase('landing');
    setActiveCase(null);
    setCaseTiming({ timings: {}, lastQIdx: -1 });
  };

  return (
    <>
      {phase === 'landing' && <Landing onStart={handleStart} />}
      {phase === 'intro' && (
        <CaseIntro caseData={activeCase} onReady={handleReady} onHome={handleRestart} />
      )}
      {phase === 'running' && (
        <CaseRunner caseData={activeCase} onCaseEnd={handleCaseEnd} onHome={handleRestart} />
      )}
      {phase === 'results' && (
        <Results activeCase={activeCase} caseTiming={caseTiming} onRestart={handleRestart} />
      )}
    </>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
